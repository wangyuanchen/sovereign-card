# ──────────────────────────────────────────────────────────
# Sovereign Card — Environment Variables
# Copy to .env.local:  cp .env.example .env.local
# ──────────────────────────────────────────────────────────

# Neon PostgreSQL connection string
# https://console.neon.tech → project → connection string
DATABASE_URL=

# GoldRush (Covalent) API Key
# https://goldrush.dev/platform/apikey
GOLDRUSH_API_KEY=

# WalletConnect Project ID (public, used client-side)
# https://cloud.walletconnect.com → new project → copy ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Vercel API Token (for custom domain management, optional)
# https://vercel.com/account/tokens
SC_VERCEL_TOKEN=

# Vercel Project ID (optional)
# Vercel dashboard → project → Settings → General
SC_VERCEL_PROJECT_ID=

# Webhook secret for payment callbacks (legacy, optional)
# Generate one: openssl rand -hex 32
WEBHOOK_SECRET=

# Stripe — one-time payment for Pro upgrade
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe Webhook signing secret
# https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for Pro upgrade product
# https://dashboard.stripe.com/products → create a product → copy price ID (price_xxx)
STRIPE_PRICE_ID=
