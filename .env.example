# ──────────────────────────────────────────────────────────
# Sovereign Card — Environment Variables
# Copy to .env.local:  cp .env.example .env.local
# ──────────────────────────────────────────────────────────

# Neon PostgreSQL connection string
# https://console.neon.tech → project → connection string
DATABASE_URL=

# GoldRush (Covalent) API Key
# https://goldrush.dev/platform/apikey
GOLDRUSH_API_KEY=

# WalletConnect Project ID (public, used client-side)
# https://cloud.walletconnect.com → new project → copy ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Vercel API Token (for custom domain management, optional)
# https://vercel.com/account/tokens
VERCEL_TOKEN=

# Vercel Project ID (optional)
# Vercel dashboard → project → Settings → General
VERCEL_PROJECT_ID=

# Webhook secret for payment callbacks (optional)
# Generate one: openssl rand -hex 32
WEBHOOK_SECRET=
